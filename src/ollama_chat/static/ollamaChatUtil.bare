# Translation helper
function tr(lang, key):
    tbl = objectGet(ollamaChatI18n, lang)
    if tbl == null:
        tbl = objectGet(ollamaChatI18n, 'en')
    endif
    val = objectGet(tbl, key)
    return if(val != null, val, key)
endfunction


