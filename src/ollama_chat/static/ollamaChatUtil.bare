# Build an SVG element from icon paths
function ollamaChatSVG(paths, size):
    return { \
        'svg': 'svg', \
        'attr': { \
            'width': size, 'height': size, \
            'viewBox': '0 0 24 24', \
            'fill': 'none', \
            'stroke': 'currentColor', \
            'stroke-width': '2', \
            'stroke-linecap': 'round', \
            'stroke-linejoin': 'round' \
        }, \
        'elem': paths \
    }
endfunction


# Helpers for theme-aware hover JS (CSS vars don't work in JS style assignments)
ollamaChatHoverOn = "var l=document.documentElement.getAttribute('data-theme')==='light';this.style.background=l?'rgba(0,0,0,0.08)':'rgba(255,255,255,0.1)';this.style.color=l?'#111827':'#f1f5f9';"
ollamaChatHoverOut = "var l=document.documentElement.getAttribute('data-theme')==='light';this.style.background='transparent';this.style.color=l?'#4b5563':'#c0c0d0';"
ollamaChatHoverBorderOn = "var l=document.documentElement.getAttribute('data-theme')==='light';this.style.borderColor=l?'#9ca3af':'#666';this.style.color=l?'#111827':'#f1f5f9';this.style.background=l?'rgba(0,0,0,0.05)':'rgba(255,255,255,0.07)';"
ollamaChatHoverBorderOut = "var l=document.documentElement.getAttribute('data-theme')==='light';this.style.borderColor=l?'#e5e7eb':'#3f3f3f';this.style.color=l?'#4b5563':'#c0c0d0';this.style.background='transparent';"


# Icon-only button (32px, for toolbars)
function ollamaChatIconBtn(paths, title, callback):
    return { \
        'html': 'button', \
        'attr': { \
            'type': 'button', \
            'title': title, \
            'style': 'display: inline-flex; align-items: center; justify-content: center; width: 32px; height: 32px; border-radius: 8px; border: none; cursor: pointer; background: transparent; color: var(--oc-text-2); padding: 0; flex-shrink: 0;', \
            'onmouseover': ollamaChatHoverOn, \
            'onmouseout': ollamaChatHoverOut \
        }, \
        'callback': {'click': callback}, \
        'elem': ollamaChatSVG(paths, '16') \
    }
endfunction


# Danger icon button (turns red on hover)
function ollamaChatIconBtnDanger(paths, title, callback):
    return { \
        'html': 'button', \
        'attr': { \
            'type': 'button', \
            'title': title, \
            'style': 'display: inline-flex; align-items: center; justify-content: center; width: 32px; height: 32px; border-radius: 8px; border: none; cursor: pointer; background: transparent; color: var(--oc-text-2); padding: 0; flex-shrink: 0;', \
            'onmouseover': "this.style.background='rgba(239,68,68,0.13)';this.style.color='#ef4444';", \
            'onmouseout': "var l=document.documentElement.getAttribute('data-theme')==='light';this.style.background='transparent';this.style.color=l?'#4b5563':'#c0c0d0';" \
        }, \
        'callback': {'click': callback}, \
        'elem': ollamaChatSVG(paths, '16') \
    }
endfunction


# Text + icon button (for action rows)
function ollamaChatTextIconBtn(paths, label, callback):
    return { \
        'html': 'button', \
        'attr': { \
            'type': 'button', \
            'style': 'display: inline-flex; align-items: center; gap: 5px; padding: 5px 10px; border-radius: 8px; border: 1px solid var(--oc-border); background: transparent; color: var(--oc-text-2); font-size: 0.78rem; cursor: pointer; font-family: inherit; white-space: nowrap;', \
            'onmouseover': ollamaChatHoverBorderOn, \
            'onmouseout': ollamaChatHoverBorderOut \
        }, \
        'callback': {'click': callback}, \
        'elem': [ollamaChatSVG(paths, '13'), {'html': 'span', 'elem': {'text': label}}] \
    }
endfunction


# Text + icon danger button (red hover)
function ollamaChatTextIconBtnDanger(paths, label, callback):
    return { \
        'html': 'button', \
        'attr': { \
            'type': 'button', \
            'style': 'display: inline-flex; align-items: center; gap: 5px; padding: 5px 10px; border-radius: 8px; border: 1px solid var(--oc-border); background: transparent; color: var(--oc-text-2); font-size: 0.78rem; cursor: pointer; font-family: inherit; white-space: nowrap;', \
            'onmouseover': "this.style.borderColor='#ef4444';this.style.color='#ef4444';this.style.background='rgba(239,68,68,0.1)';", \
            'onmouseout': "var l=document.documentElement.getAttribute('data-theme')==='light';this.style.borderColor=l?'#e5e7eb':'#3f3f3f';this.style.color=l?'#4b5563':'#c0c0d0';this.style.background='transparent';" \
        }, \
        'callback': {'click': callback}, \
        'elem': [ollamaChatSVG(paths, '13'), {'html': 'span', 'elem': {'text': label}}] \
    }
endfunction


# Primary action button (filled green, for "Use Model" etc.)
function ollamaChatPrimaryBtn(label, callback):
    return { \
        'html': 'button', \
        'attr': { \
            'type': 'button', \
            'style': 'display: inline-flex; align-items: center; gap: 6px; padding: 8px 16px; border-radius: 8px; border: none; background: var(--oc-accent); color: white; font-size: 0.875rem; font-weight: 500; cursor: pointer; font-family: inherit;', \
            'onmouseover': "this.style.background='#0a7a5e';", \
            'onmouseout': "this.style.background=document.documentElement.getAttribute('data-theme')==='light'?'#0d8f6e':'#10a37f';" \
        }, \
        'callback': {'click': callback}, \
        'elem': [ollamaChatSVG(ollamaChatIconCheck, '14'), {'html': 'span', 'elem': {'text': label}}] \
    }
endfunction


# Full-width dashed "Add" button (for adding prompts/variables in editor)
function ollamaChatAddBtn(paths, label, callback):
    return { \
        'html': 'button', \
        'attr': { \
            'type': 'button', \
            'style': 'display: flex; align-items: center; justify-content: center; gap: 7px; width: 100%; max-width: 700px; padding: 9px 16px; border-radius: 10px; border: 1.5px dashed var(--oc-border); background: transparent; color: var(--oc-text-2); font-size: 0.875rem; cursor: pointer; font-family: inherit;', \
            'onmouseover': "this.style.borderColor=document.documentElement.getAttribute('data-theme')==='light'?'#374151':'#c0c0d0';this.style.color=document.documentElement.getAttribute('data-theme')==='light'?'#111827':'#ececec';this.style.background=document.documentElement.getAttribute('data-theme')==='light'?'rgba(0,0,0,0.04)':'rgba(255,255,255,0.05)';", \
            'onmouseout': "this.style.borderColor='var(--oc-border)';this.style.color='var(--oc-text-2)';this.style.background='transparent';" \
        }, \
        'callback': {'click': callback}, \
        'elem': [ollamaChatSVG(paths, '16'), {'html': 'span', 'elem': {'text': label}}] \
    }
endfunction


# Send message button (white circle with arrow-up)
function ollamaChatSendBtn(callback):
    return { \
        'html': 'button', \
        'attr': { \
            'type': 'button', \
            'title': 'Send message', \
            'style': 'display: inline-flex; align-items: center; justify-content: center; width: 34px; height: 34px; border-radius: 50%; border: none; cursor: pointer; background: var(--oc-text); color: var(--oc-bg); flex-shrink: 0; padding: 0;', \
            'onmouseover': "this.style.opacity='0.85';", \
            'onmouseout': "this.style.opacity='1';" \
        }, \
        'callback': {'click': callback}, \
        'elem': { \
            'svg': 'svg', 'attr': {'width': '16', 'height': '16', 'viewBox': '0 0 24 24', 'fill': 'none', 'stroke': 'currentColor', 'stroke-width': '2.5', 'stroke-linecap': 'round', 'stroke-linejoin': 'round'}, \
            'elem': ollamaChatIconArrowUp \
        } \
    }
endfunction


# Stop generation button (white circle with stop square)
function ollamaChatStopBtn(callback):
    return { \
        'html': 'button', \
        'attr': { \
            'type': 'button', \
            'title': 'Stop generating', \
            'style': 'display: inline-flex; align-items: center; justify-content: center; width: 34px; height: 34px; border-radius: 50%; border: 2px solid var(--oc-text); cursor: pointer; background: transparent; color: var(--oc-text); flex-shrink: 0; padding: 0;', \
            'onmouseover': "this.style.background='rgba(255,255,255,0.15)';", \
            'onmouseout': "this.style.background='transparent';" \
        }, \
        'callback': {'click': callback}, \
        'elem': { \
            'svg': 'svg', 'attr': {'width': '12', 'height': '12', 'viewBox': '0 0 24 24', 'fill': 'currentColor', 'stroke': 'none'}, \
            'elem': {'svg': 'rect', 'attr': {'x': '4', 'y': '4', 'width': '16', 'height': '16', 'rx': '2'}} \
        } \
    }
endfunction


# The Ollama Chat error page
function ollamaChatErrorPage(message):
    documentSetTitle(ollamaChatTitle)
    markdownPrint( \
        argsLink(ollamaChatArguments, 'Back', null, true), \
        '', \
        '# ' + markdownEscape(ollamaChatTitle), \
        '', \
        '**ERROR:** ' + markdownEscape(message) \
    )
endfunction


# Local SVG icon paths used only inside the sidebar
ollamaChatSidebarIconChat = [{'svg': 'path', 'attr': {'d': 'M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z'}}]
ollamaChatSidebarIconLayers = [ \
    {'svg': 'polygon', 'attr': {'points': '12 2 2 7 12 12 22 7 12 2'}}, \
    {'svg': 'polyline', 'attr': {'points': '2 17 12 22 22 17'}}, \
    {'svg': 'polyline', 'attr': {'points': '2 12 12 17 22 12'}} \
]
ollamaChatSidebarIconSliders = [ \
    {'svg': 'line', 'attr': {'x1': '4', 'y1': '21', 'x2': '4', 'y2': '14'}}, \
    {'svg': 'line', 'attr': {'x1': '4', 'y1': '10', 'x2': '4', 'y2': '3'}}, \
    {'svg': 'line', 'attr': {'x1': '12', 'y1': '21', 'x2': '12', 'y2': '12'}}, \
    {'svg': 'line', 'attr': {'x1': '12', 'y1': '8', 'x2': '12', 'y2': '3'}}, \
    {'svg': 'line', 'attr': {'x1': '20', 'y1': '21', 'x2': '20', 'y2': '16'}}, \
    {'svg': 'line', 'attr': {'x1': '20', 'y1': '12', 'x2': '20', 'y2': '3'}}, \
    {'svg': 'line', 'attr': {'x1': '1', 'y1': '14', 'x2': '7', 'y2': '14'}}, \
    {'svg': 'line', 'attr': {'x1': '9', 'y1': '8', 'x2': '15', 'y2': '8'}}, \
    {'svg': 'line', 'attr': {'x1': '17', 'y1': '16', 'x2': '23', 'y2': '16'}} \
]


# Helper: a single sidebar nav link row (icon + label)
function ollamaChatSidebarNavItem(iconPaths, label, url):
    return { \
        'html': 'a', \
        'attr': { \
            'href': url, \
            'style': 'display: flex; align-items: center; gap: 10px; padding: 8px 10px; border-radius: 8px; color: #c0c0d0; font-size: 0.875rem; font-weight: 400;', \
            'onmouseover': "this.style.background='rgba(255,255,255,0.07)';this.style.color='#ececec';", \
            'onmouseout': "this.style.background='transparent';this.style.color='#c0c0d0';" \
        }, \
        'elem': [ \
            ollamaChatSVG(iconPaths, '16'), \
            {'html': 'span', 'elem': {'text': label}} \
        ] \
    }
endfunction


# Render the sidebar navigation
async function ollamaChatSidebar(activeConvId, lang):
    # Fetch conversations for sidebar
    conversationsResponse = systemFetch('getConversations')
    conversationsResponse = if(conversationsResponse != null, jsonParse(conversationsResponse))
    currentModel = if(conversationsResponse != null, objectGet(conversationsResponse, 'model'))
    conversations = if(conversationsResponse != null, objectGet(conversationsResponse, 'conversations'))

    newChatURL = argsURL(ollamaChatArguments, {'lang': lang}, true)

    # Build conversation list items
    convItems = []

    # "New Chat" button → opens blank new chat directly
    arrayPush(convItems, { \
        'html': 'a', \
        'attr': { \
            'href': newChatURL, \
            'style': 'display: flex; align-items: center; gap: 10px; padding: 8px 10px; border-radius: 8px; color: var(--oc-accent); font-size: 0.875rem; font-weight: 500; margin-bottom: 4px;', \
            'onmouseover': "this.style.background='rgba(255,255,255,0.07)';", \
            'onmouseout': "this.style.background='transparent';" \
        }, \
        'elem': [ \
            { \
                'html': 'div', \
                'attr': {'style': 'width: 28px; height: 28px; border-radius: 7px; border: 1.5px solid var(--oc-accent); display: flex; align-items: center; justify-content: center; flex-shrink: 0;'}, \
                'elem': ollamaChatSVG(ollamaChatIconPlus, '14') \
            }, \
            {'html': 'span', 'elem': {'text': tr(lang, 'new_chat')}} \
        ] \
    })

    # Conversation items
    if conversations:
        if arrayLength(conversations):
            arrayPush(convItems, { \
                'html': 'div', \
                'attr': {'style': 'font-size: 0.7rem; font-weight: 600; color: var(--oc-text-4); text-transform: uppercase; letter-spacing: 0.06em; padding: 8px 10px 4px;'}, \
                'elem': {'text': tr(lang, 'conversations')} \
            })
        endif
        for conv in conversations:
            convId = objectGet(conv, 'id')
            convTitle = objectGet(conv, 'title')
            convGenerating = objectGet(conv, 'generating')
            isActive = convId == activeConvId
            convURL = argsURL(ollamaChatArguments, {'view': 'chat', 'id': convId}, false, \
                if(convGenerating, 'chat-bottom'))

            activeBg = if(isActive, 'var(--oc-sidebar-hover)', 'transparent')
            activeColor = if(isActive, '#ececec', '#9a9aaa')

            # Generating dot indicator
            generatingDot = if(convGenerating, { \
                'html': 'div', \
                'attr': {'style': 'width: 6px; height: 6px; border-radius: 50%; background: var(--oc-accent); flex-shrink: 0; margin-left: auto;'} \
            })

            # Delete icon button — always visible on mobile, hover-only on desktop
            deleteBtnId = 'oc-sdel-' + convId
            deleteBtn = { \
                'html': 'button', \
                'attr': { \
                    'type': 'button', \
                    'id': deleteBtnId, \
                    'title': 'Delete conversation', \
                    'class': 'oc-conv-del-btn', \
                    'style': 'display: inline-flex; align-items: center; justify-content: center; width: 30px; height: 30px; border-radius: 7px; border: none; cursor: pointer; background: transparent; color: #777788; padding: 0; flex-shrink: 0; margin-left: auto;', \
                    'onmouseover': "this.style.background='rgba(239,68,68,0.15)';this.style.color='#ef4444';event.stopPropagation();", \
                    'onmouseout': "this.style.background='transparent';this.style.color='#777788';event.stopPropagation();", \
                    'onclick': "event.preventDefault();event.stopPropagation();if(confirm('Delete this conversation?')){fetch('deleteConversation',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({id:'" + convId + "'})}).then(function(){window.location.replace(window.location.pathname+'#');});}" \
                }, \
                'elem': ollamaChatSVG(ollamaChatIconTrash, '15') \
            }

            # Outer element is <a> so it works on mobile with a single tap (no double-tap issue)
            arrayPush(convItems, { \
                'html': 'a', \
                'attr': { \
                    'href': convURL, \
                    'style': 'display: flex; align-items: center; gap: 8px; padding: 6px 8px; border-radius: 8px; margin-bottom: 1px; background: ' + activeBg + '; text-decoration: none;', \
                    'onmouseover': "this.style.background='rgba(255,255,255,0.07)';", \
                    'onmouseout': "this.style.background='" + activeBg + "';" \
                }, \
                'elem': [ \
                    { \
                        'html': 'div', \
                        'attr': {'style': 'flex-shrink: 0; color: ' + if(isActive, 'var(--oc-accent)', '#777788') + ';'}, \
                        'elem': ollamaChatSVG(ollamaChatSidebarIconChat, '15') \
                    }, \
                    { \
                        'html': 'span', \
                        'attr': {'style': 'flex: 1; min-width: 0; font-size: 0.85rem; color: ' + activeColor + '; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; font-weight: ' + if(isActive, '500', '400') + ';'}, \
                        'elem': {'text': convTitle} \
                    }, \
                    if(!convGenerating, { \
                        'html': 'button', \
                        'attr': { \
                            'type': 'button', \
                            'title': 'Edit title', \
                            'class': 'oc-conv-edit-btn', \
                            'style': 'display: inline-flex; align-items: center; justify-content: center; width: 24px; height: 24px; border-radius: 5px; border: none; cursor: pointer; background: transparent; color: #555; padding: 0; flex-shrink: 0;', \
                            'onmouseover': "this.style.background='rgba(255,255,255,0.12)';this.style.color='#ececec';event.stopPropagation();", \
                            'onmouseout': "this.style.background='transparent';this.style.color='#555';event.stopPropagation();", \
                            'onclick': "event.preventDefault();event.stopPropagation();ocEditTitle('" + convId + "','" + urlEncodeComponent(convTitle) + "');" \
                        }, \
                        'elem': ollamaChatSVG(ollamaChatIconEdit, '12') \
                    }), \
                    if(convGenerating, generatingDot, deleteBtn) \
                ] \
            })
        endfor
    else:
        arrayPush(convItems, { \
            'html': 'div', \
            'attr': {'style': 'padding: 8px 10px; font-size: 0.8rem; color: var(--oc-text-4); font-style: italic;'}, \
            'elem': {'text': tr(lang, 'no_conversations')} \
        })
    endif

    # Bottom nav items with icons
    # Model item: if active model exists, show name + deactivate button; else show "Select Model"
    modelNavItem = if(currentModel, \
        { \
            'html': 'div', \
            'attr': {'style': 'display: flex; align-items: center; gap: 4px; padding: 4px 4px 4px 10px; border-radius: 8px;', \
                'onmouseover': "this.style.background='rgba(255,255,255,0.07)';", \
                'onmouseout': "this.style.background='transparent';"}, \
            'elem': [ \
                { \
                    'html': 'a', \
                    'attr': {'href': argsURL(ollamaChatArguments, {'view': 'models'}, false), \
                        'style': 'display: flex; align-items: center; gap: 10px; flex: 1; min-width: 0; color: #c0c0d0; font-size: 0.875rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;'}, \
                    'elem': [ollamaChatSVG(ollamaChatSidebarIconLayers, '16'), {'html': 'span', 'elem': {'text': currentModel}}] \
                }, \
                { \
                    'html': 'button', \
                    'attr': { \
                        'type': 'button', \
                        'title': 'Deactivate model', \
                        'style': 'display: inline-flex; align-items: center; justify-content: center; width: 24px; height: 24px; border-radius: 6px; border: none; cursor: pointer; background: transparent; color: #555; padding: 0; flex-shrink: 0;', \
                        'onmouseover': "this.style.color='#ef4444';this.style.background='rgba(239,68,68,0.15)';event.stopPropagation();", \
                        'onmouseout': "this.style.color='#555';this.style.background='transparent';" \
                    }, \
                    'callback': {'click': ollamaChatSidebarOnClearModel}, \
                    'elem': ollamaChatSVG([{'svg': 'line', 'attr': {'x1': '18', 'y1': '6', 'x2': '6', 'y2': '18'}}, {'svg': 'line', 'attr': {'x1': '6', 'y1': '6', 'x2': '18', 'y2': '18'}}], '14') \
                } \
            ] \
        }, \
        ollamaChatSidebarNavItem(ollamaChatSidebarIconLayers, tr(lang, 'select_model'), \
            argsURL(ollamaChatArguments, {'view': 'models'}, false)) \
    )

    bottomItems = [ \
        modelNavItem, \
        ollamaChatSidebarNavItem(ollamaChatIconTranslate, tr(lang, 'translator'), \
            argsURL(ollamaChatArguments, {'view': 'translate'}, false)), \
        ollamaChatSidebarNavItem(ollamaChatIconProofread, tr(lang, 'proofreader'), \
            argsURL(ollamaChatArguments, {'view': 'grammar'}, false)), \
        ollamaChatSidebarNavItem(ollamaChatIconTemplate, tr(lang, 'manage_templates'), \
            argsURL(ollamaChatArguments, {'view': 'templates'}, false)), \
        ollamaChatSidebarNavItem(ollamaChatIconSettings, tr(lang, 'settings'), \
            argsURL(ollamaChatArguments, {'view': 'settings'}, false)), \
        ollamaChatSidebarNavItem(ollamaChatIconHelp, tr(lang, 'help'), \
            argsURL(ollamaChatArguments, {'view': 'help'}, false)) \
    ]

    # Expand button — visible on desktop only when sidebar is collapsed
    elementModelRender({ \
        'html': 'button', \
        'attr': { \
            'class': 'oc-expand-btn', \
            'type': 'button', \
            'title': 'Expand sidebar', \
            'style': 'display: none; position: fixed; top: 12px; left: 12px; z-index: 200; width: 36px; height: 36px; border-radius: 8px; border: 1px solid var(--oc-sidebar-border); background: var(--oc-sidebar-bg); color: #c0c0d0; cursor: pointer; align-items: center; justify-content: center; padding: 0;', \
            'onmouseover': "this.style.color='#ececec';", \
            'onmouseout': "this.style.color='#c0c0d0';", \
            'onclick': "var h=document.documentElement;h.classList.remove('oc-collapsed');localStorage.setItem('oc-sidebar','expanded');" \
        }, \
        'elem': ollamaChatSVG([{'svg': 'path', 'attr': {'d': 'M13 5l7 7-7 7'}}, {'svg': 'path', 'attr': {'d': 'M6 5l7 7-7 7'}}], '14') \
    })

    # Mobile top app bar (visible only on small screens via CSS)
    elementModelRender({ \
        'html': 'div', \
        'attr': { \
            'class': 'oc-topbar', \
            'style': 'display: none; position: fixed; top: 0; left: 0; right: 0; height: 52px; background: var(--oc-sidebar-bg); border-bottom: 1px solid var(--oc-sidebar-border); z-index: 150; align-items: center; padding: 0 12px; gap: 10px;' \
        }, \
        'elem': [ \
            { \
                'html': 'button', \
                'attr': { \
                    'type': 'button', \
                    'title': 'Open menu', \
                    'style': 'width: 36px; height: 36px; border-radius: 8px; border: none; background: transparent; color: #c0c0d0; cursor: pointer; display: flex; align-items: center; justify-content: center; padding: 0; flex-shrink: 0;', \
                    'onmouseover': "this.style.background='rgba(255,255,255,0.1)';", \
                    'onmouseout': "this.style.background='transparent';", \
                    'onclick': "var s=document.querySelector('.oc-sidebar');if(s){s.classList.toggle('oc-open');var o=document.querySelector('.oc-overlay');if(o)o.style.display=s.classList.contains('oc-open')?'block':'none';}" \
                }, \
                'elem': ollamaChatSVG(ollamaChatIconMenu, '20') \
            }, \
            { \
                'html': 'span', \
                'attr': {'style': 'flex: 1; font-size: 0.95rem; font-weight: 600; color: #ececec; user-select: none; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;'}, \
                'elem': {'text': tr(lang, 'app_title')} \
            }, \
            { \
                'html': 'a', \
                'attr': { \
                    'href': newChatURL, \
                    'title': tr(lang, 'new_chat'), \
                    'style': 'width: 36px; height: 36px; border-radius: 8px; border: 1px solid rgba(255,255,255,0.12); background: transparent; color: #c0c0d0; display: flex; align-items: center; justify-content: center; padding: 0; flex-shrink: 0; text-decoration: none;', \
                    'onmouseover': "this.style.background='rgba(255,255,255,0.1)';this.style.color='#ececec';", \
                    'onmouseout': "this.style.background='transparent';this.style.color='#c0c0d0';" \
                }, \
                'elem': ollamaChatSVG(ollamaChatIconPlus, '18') \
            } \
        ] \
    })

    # Mobile overlay to close sidebar by tapping outside
    elementModelRender({ \
        'html': 'div', \
        'attr': { \
            'class': 'oc-overlay', \
            'style': 'display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 99;', \
            'onclick': "this.style.display='none';document.querySelector('.oc-sidebar').classList.remove('oc-open');" \
        } \
    })

    # Render the full sidebar
    elementModelRender({ \
        'html': 'div', \
        'attr': { \
            'class': 'oc-sidebar', \
            'style': 'position: fixed; left: 0; top: 0; width: 260px; height: 100vh; background: var(--oc-sidebar-bg); display: flex; flex-direction: column; overflow: hidden; z-index: 100; border-right: 1px solid var(--oc-sidebar-border);' \
        }, \
        'elem': [ \
            # Header: logo + collapse button
            { \
                'html': 'div', \
                'attr': {'style': 'padding: 14px 12px 10px; flex-shrink: 0; display: flex; align-items: center; gap: 8px;'}, \
                'elem': [ \
                    { \
                        'html': 'div', \
                        'attr': {'style': 'width: 30px; height: 30px; border-radius: 8px; background: var(--oc-accent); display: flex; align-items: center; justify-content: center; flex-shrink: 0;'}, \
                        'elem': ollamaChatSVG([{'svg': 'path', 'attr': {'d': 'M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z', 'fill': 'white', 'stroke': 'none'}}], '16') \
                    }, \
                    { \
                        'html': 'span', \
                        'attr': {'style': 'font-weight: 600; font-size: 0.95rem; color: #ececec; flex: 1; user-select: none;'}, \
                        'elem': {'text': tr(lang, 'app_title')} \
                    }, \
                    { \
                        'html': 'button', \
                        'attr': { \
                            'type': 'button', \
                            'title': 'Collapse sidebar', \
                            'style': 'width: 28px; height: 28px; border-radius: 7px; border: none; background: transparent; color: #777788; cursor: pointer; display: flex; align-items: center; justify-content: center; padding: 0; flex-shrink: 0;', \
                            'onmouseover': "this.style.background='rgba(255,255,255,0.1)';this.style.color='#ececec';", \
                            'onmouseout': "this.style.background='transparent';this.style.color='#777788';", \
                            'onclick': "var isMobile=window.innerWidth<768;if(isMobile){var s=document.querySelector('.oc-sidebar');if(s)s.classList.remove('oc-open');var o=document.querySelector('.oc-overlay');if(o)o.style.display='none';}else{var h=document.documentElement;h.classList.toggle('oc-collapsed');localStorage.setItem('oc-sidebar',h.classList.contains('oc-collapsed')?'collapsed':'expanded');}" \
                        }, \
                        'elem': ollamaChatSVG([{'svg': 'path', 'attr': {'d': 'M11 19l-7-7 7-7'}}, {'svg': 'path', 'attr': {'d': 'M18 19l-7-7 7-7'}}], '14') \
                    } \
                ] \
            }, \
            # Conversation list (scrollable)
            { \
                'html': 'div', \
                'attr': {'style': 'flex: 1; overflow-y: auto; padding: 4px 8px; min-height: 0;'}, \
                'elem': convItems \
            }, \
            # Bottom nav
            { \
                'html': 'div', \
                'attr': {'style': 'padding: 8px; border-top: 1px solid var(--oc-sidebar-border); flex-shrink: 0;'}, \
                'elem': bottomItems \
            } \
        ] \
    })
endfunction


# Deactivate (clear) the current model
async function ollamaChatSidebarOnClearModel():
    systemFetch({'url': 'clearModel', 'body': jsonStringify({})})
    windowSetLocation(argsURL(ollamaChatArguments, null, true))
endfunction


# Delete conversation from sidebar
async function ollamaChatSidebarOnDeleteConv(convId):
    systemFetch({'url': 'deleteConversation', 'body': jsonStringify({'id': convId})})
    windowSetLocation(argsURL(ollamaChatArguments, {'view': null, 'id': null, 'action': null, 'actionID': null}, true))
endfunction
