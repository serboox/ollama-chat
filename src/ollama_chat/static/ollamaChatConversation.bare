include <args.bare>
include <forms.bare>

include 'ollamaChatUtil.bare'


# The Ollama Chat conversation page
async function ollamaChatConversationPage(args):
    id = objectGet(args, 'id')
    lang = objectGet(args, 'lang')

    # No conversation ID — redirect to home screen (centered input)
    if id == null:
        windowSetLocation(argsURL(ollamaChatArguments, {'view': null, 'id': null, 'action': null}, true))
        return
    endif

    # Fetch the conversation
    if id != null:
        conversationResponse = systemFetch('getConversation?id=' + id)
        conversationResponse = if(conversationResponse != null, jsonParse(conversationResponse))
        if conversationResponse == null:
            ollamaChatErrorPage('Unknown conversation ID')
            return
        endif
        conversation = objectGet(conversationResponse, 'conversation')
        title = objectGet(conversation, 'title')
        model = objectGet(conversation, 'model')
        generating = objectGet(conversation, 'generating')
    else:
        conversation = null
        title = ollamaChatTitle
        model = null
        generating = false
    endif

    # Render the sidebar
    ollamaChatSidebar(id, lang)

    # Hidden input for image attachment (read by send handlers)
    elementModelRender({'html': 'input', 'attr': {'type': 'hidden', 'id': 'oc-img-b64', 'value': ''}})

    # Render the bottom input bar (fixed)
    elementModelRender(ollamaChatConversationInputBarElements(args, conversation, generating))
    documentSetFocus(ollamaChatConversationPromptID)

    # Render the chat title
    documentSetTitle(title)
    if conversation != null:
        # Header: title + model name only (edit via modal, no inline form)
        elementModelRender({'html': 'div', 'attr': {'style': 'margin-bottom: 1rem;'}, 'elem': [ \
            {'html': 'h1', 'attr': {'style': 'margin: 0 0 0.2rem 0; font-size: 1.2rem; color: var(--oc-text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;'}, 'elem': {'text': title}}, \
            {'html': 'div', 'attr': {'style': 'font-size: 0.78rem; color: var(--oc-text-3);'}, 'elem': {'text': model}} \
        ]})
    endif

    # No conversation yet — show template picker if templates exist
    exchanges = objectGet(conversation, 'exchanges')
    if conversation == null || !exchanges:
        if conversation == null:
            ollamaChatConversationNewChatArea(args, lang)
        endif
        return
    endif

    # Render the exchanges
    ixExchangeLast = arrayLength(exchanges) - 1
    for exchange, ixExchange in exchanges:
        # User message bubble
        elementModelRender({ \
            'html': 'div', \
            'attr': {'style': 'display: flex; justify-content: flex-end; margin-bottom: 1.25rem;'}, \
            'elem': { \
                'html': 'div', \
                'attr': { \
                    'style': 'background: var(--oc-bubble); border-radius: 18px; padding: 0.75rem 1rem; max-width: 75%; white-space: pre-wrap; color: var(--oc-text); font-size: 0.95rem; border: 1px solid var(--oc-bubble-border);' \
                }, \
                'elem': {'text': objectGet(exchange, 'user')} \
            } \
        })

        # Model response header
        elementModelRender({ \
            'html': 'div', \
            'attr': {'style': 'display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.5rem;'}, \
            'elem': [ \
                { \
                    'html': 'div', \
                    'attr': { \
                        'style': 'width: 28px; height: 28px; border-radius: 50%; background: var(--oc-accent); display: flex; align-items: center; justify-content: center; font-size: 0.7rem; font-weight: 600; color: white; flex-shrink: 0;' \
                    }, \
                    'elem': {'text': 'AI'} \
                }, \
                { \
                    'html': 'span', \
                    'attr': {'style': 'font-size: 0.8rem; color: var(--oc-text-2);'}, \
                    'elem': {'text': model} \
                } \
            ] \
        })

        ollamaChatConversationResponseRenderTop(args, exchange, ixExchange)
        if ixExchange != ixExchangeLast:
            ollamaChatConversationResponseRenderBottom(args, exchange, ixExchange)
        endif

        # Separator between exchanges (not after last)
        if ixExchange != ixExchangeLast:
            elementModelRender({'html': 'div', 'attr': {'style': 'border-top: 1px solid var(--oc-border); margin: 1.25rem 0;'}})
        endif
    endfor

    # Render the document reset ID
    elementModelRender({'html': 'div', 'attr': {'id': ollamaChatConversationResetID, 'style': 'display: none;'}})

    # Render the bottom of the conversation page
    ollamaChatConversationPageBottom(args, conversation, generating)
endfunction


# Helper to render the bottom of Ollama Chat conversation page
async function ollamaChatConversationPageBottom(args, conversation, generating):
    multiline = objectGet(args, 'multiline')
    lang = objectGet(args, 'lang')

    # Any exchanges?
    isThinking = false
    exchanges = objectGet(conversation, 'exchanges')
    if arrayLength(exchanges):
        # Thinking?
        ixLastExchange = arrayLength(exchanges) - 1
        lastExchange = arrayGet(exchanges, ixLastExchange)
        isThinking = objectHas(lastExchange, 'thinking')

        # Render the model reply
        ollamaChatConversationResponseRenderBottom(args, lastExchange, ixLastExchange)

        # Render the delete and regenerate buttons below last exchange
        # Use onclick+fetch+reload for reliability (bare-script callbacks don't re-render the page)
        convId = objectGet(args, 'id')
        if !generating:
            elementModelRender( \
                {'html': 'div', 'attr': {'style': 'display: flex; gap: 0.25rem; margin-top: 0.75rem;'}, 'elem': [ \
                    { \
                        'html': 'button', 'attr': { \
                            'type': 'button', \
                            'style': 'display: inline-flex; align-items: center; gap: 5px; padding: 5px 10px; border-radius: 8px; border: 1px solid var(--oc-border); background: transparent; color: var(--oc-text-2); font-size: 0.78rem; cursor: pointer; font-family: inherit; white-space: nowrap;', \
                            'onmouseover': ollamaChatHoverBorderOn, 'onmouseout': ollamaChatHoverBorderOut, \
                            'onclick': "fetch('regenerateConversationExchange',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({id:'" + convId + "'})}).then(function(){location.reload();});" \
                        }, \
                        'elem': [ollamaChatSVG(ollamaChatIconRefresh, '13'), {'html': 'span', 'elem': {'text': tr(lang, 'regenerate')}}] \
                    }, \
                    { \
                        'html': 'button', 'attr': { \
                            'type': 'button', \
                            'style': 'display: inline-flex; align-items: center; gap: 5px; padding: 5px 10px; border-radius: 8px; border: 1px solid var(--oc-border); background: transparent; color: var(--oc-text-2); font-size: 0.78rem; cursor: pointer; font-family: inherit; white-space: nowrap;', \
                            'onmouseover': "this.style.borderColor='#ef4444';this.style.color='#ef4444';this.style.background='rgba(239,68,68,0.1)';", \
                            'onmouseout': "this.style.borderColor='var(--oc-border)';this.style.color='var(--oc-text-2)';this.style.background='transparent';", \
                            'onclick': "fetch('deleteConversationExchange',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({id:'" + convId + "'})}).then(function(){location.reload();});" \
                        }, \
                        'elem': [ollamaChatSVG(ollamaChatIconTrash, '13'), {'html': 'span', 'elem': {'text': tr(lang, 'delete')}}] \
                    } \
                ]} \
            )
        endif
    endif

    # Render the bottom space (for fixed input bar)
    fontSizePx = documentFontSize()
    bottomSpacePx = if(generating, mathFloor(0.67 * windowHeight() / fontSizePx), if(multiline, 18, 12)) * fontSizePx
    bottomElementId = stringSlice(argsURL(ollamaChatArguments, null, false, ollamaChatConversationBottomID), 1)
    elementModelRender([ \
        {'html': 'div', 'attr': {'style': 'height: ' + numberToFixed(bottomSpacePx, ollamaChatConversationSVGPrecision) + 'px'}}, \
        {'html': 'div', 'attr': {'id': bottomElementId}} \
    ])

    # Set the conversation update timeout
    if generating:
        windowSetTimeout( \
            systemPartial(ollamaChatConversationOnTimeout, args, arrayLength(exchanges), isThinking), \
            ollamaChatConversationTimeoutMs \
        )
    endif
endfunction


# Helper to render the model response top part
function ollamaChatConversationResponseRenderTop(args, exchange, ixExchange):
    lang = objectGet(args, 'lang')

    # Text view?
    if objectGet(args, 'text'):
        return
    endif

    # Show/hide thinking button?
    isThinking = objectHas(exchange, 'thinking')
    if isThinking:
        thinkLabel = if(ixExchange == objectGet(args, 'think'), tr(lang, 'hide_thinking'), tr(lang, 'show_thinking'))
        thinkURL = if(ixExchange == objectGet(args, 'think'), argsURL(ollamaChatArguments, {'think': null}), argsURL(ollamaChatArguments, {'think': ixExchange}))
        elementModelRender({ \
            'html': 'a', \
            'attr': { \
                'href': thinkURL, \
                'style': 'display: inline-flex; align-items: center; gap: 4px; padding: 3px 10px; border-radius: 20px; border: 1px solid var(--oc-border); color: var(--oc-text-2); font-size: 0.78rem; text-decoration: none; margin-bottom: 0.5rem;', \
                'onmouseover': ollamaChatHoverBorderOn, \
                'onmouseout': ollamaChatHoverBorderOut \
            }, \
            'elem': [ollamaChatSVG([{'svg': 'circle', 'attr': {'cx': '12', 'cy': '12', 'r': '3'}}, {'svg': 'path', 'attr': {'d': 'M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14'}}], '13'), {'html': 'span', 'elem': {'text': thinkLabel}}] \
        })
    endif
endfunction


# Helper to render the model response bottom part
function ollamaChatConversationResponseRenderBottom(args, exchange, ixExchange):
    # Text view?
    if objectGet(args, 'text'):
        elementModelRender({'html': 'pre', 'elem': {'text': objectGet(exchange, 'model')}})
        return
    endif

    # Thinking response?
    thinking = objectGet(exchange, 'thinking')
    if thinking && ixExchange == objectGet(args, 'think'):
        markdownPrint('', '**<think>**', '', thinking, '', '**</think>**', '', '-----')
    endif

    # Render the response
    markdownPrint('', objectGet(exchange, 'model'))
endfunction


# Format token count as compact string (21 → "21", 4096 → "4K", 131072 → "128K")
function ollamaChatFmtTokens(n):
    if n >= 1000:
        return numberToFixed(mathFloor(n / 1000), 0) + 'K'
    endif
    return numberToFixed(n, 0)
endfunction


# Helper to render context/token usage info for an exchange
function ollamaChatConversationTokenInfo(exchange):
    promptTokens = objectGet(exchange, 'promptTokens')
    if promptTokens == null:
        return
    endif
    responseTokens = objectGet(exchange, 'responseTokens')
    responseTokens = if(responseTokens != null, responseTokens, 0)
    contextSize = objectGet(exchange, 'contextSize')
    totalTokens = promptTokens + responseTokens
    if contextSize != null && contextSize > 0:
        remaining = contextSize - totalTokens
        pct = mathFloor(1000 * totalTokens / contextSize) / 10
        tokenInfo = ollamaChatFmtTokens(totalTokens) + ' / ' + ollamaChatFmtTokens(contextSize) + ' tokens (' + numberToFixed(pct, 1) + '% used)'
    else:
        tokenInfo = ollamaChatFmtTokens(promptTokens) + ' prompt + ' + ollamaChatFmtTokens(responseTokens) + ' response = ' + ollamaChatFmtTokens(totalTokens) + ' tokens'
    endif
    elementModelRender({ \
        'html': 'div', \
        'attr': {'style': 'font-size: 0.75rem; color: var(--oc-text-3); margin-top: 0.5rem;'}, \
        'elem': {'text': tokenInfo} \
    })
endfunction


# Conversation update timeout handler
async function ollamaChatConversationOnTimeout(args, originalExchangeCount, originalThinking):
    id = objectGet(args, 'id')

    # Fetch the conversation
    conversationResponse = systemFetch('getConversation?id=' + id)
    conversationResponse = if(conversationResponse != null, jsonParse(conversationResponse))
    if conversationResponse == null:
        ollamaChatErrorPage('Unknown conversation ID')
        return
    endif
    conversation = objectGet(conversationResponse, 'conversation')
    generating = objectGet(conversation, 'generating')

    # Done generating? Re-render the page to update the floating controls
    if !generating:
        ollamaChatConversationSavePrompt()
        ollamaChatConversationPage(args)
        return
    endif

    # Has anything changed that requires a re-render?
    exchanges = objectGet(conversation, 'exchanges')
    exchangeCount = arrayLength(exchanges)
    lastExchange = arrayGet(exchanges, exchangeCount - 1)
    isThinking = objectHas(lastExchange, 'thinking')
    if exchangeCount != originalExchangeCount || isThinking != originalThinking:
        ollamaChatConversationPage(args)
        return
    endif

    # Render the page bottom
    documentSetReset(ollamaChatConversationResetID)
    ollamaChatConversationPageBottom(args, conversation, generating)
endfunction


# The conversation refresh period, in milliseconds
ollamaChatConversationTimeoutMs = 500


# The conversation prompt input ID
ollamaChatConversationPromptID = 'ollama-chat-prompt'


# The conversation title input ID
ollamaChatConversationTitleID = 'ollama-chat-title'


# The conversation prompt session storage key
ollamaChatConversationSessionKey = 'ollama-chat-conversation-message'


# The conversation document reset ID
ollamaChatConversationResetID = 'ollama-chat-document-reset-id'


# The conversation bottom element ID (for scroll to bottom)
ollamaChatConversationBottomID = 'chat-bottom'


# The SVG numeric attribute precision
ollamaChatConversationSVGPrecision = 3


# Helper to save the prompt to session storage prior to a full re-render
function ollamaChatConversationSavePrompt():
    prompt = stringTrim(documentInputValue(ollamaChatConversationPromptID))
    if prompt != '':
        sessionStorageSet(ollamaChatConversationSessionKey, prompt)
    endif
endfunction


# Generic conversation button on-click event handler
async function ollamaChatConversationOnClick(args, api, url, noSave):
    # Call the api, if any
    if api != null:
        systemFetch({'url': api, 'body': jsonStringify({'id': objectGet(args, 'id')})})
    endif

    # Navigate?
    if url != null:
        if !noSave:
            ollamaChatConversationSavePrompt()
        endif
        windowSetLocation(url)
    else:
        # Re-render the current conversation page in place
        ollamaChatConversationSavePrompt()
        ollamaChatConversationPage(args)
    endif
endfunction


# Title update click handler
async function ollamaChatConversationOnTitleUpdate(args):
    # Update the conversation title
    title = stringTrim(documentInputValue(ollamaChatConversationTitleID))
    if title:
        systemFetch({ \
            'url': 'setConversationTitle', \
            'body': jsonStringify({'id': objectGet(args, 'id'), 'title': title}) \
        })
    endif

    # Navigate to the conversation
    ollamaChatConversationSavePrompt()
    windowSetLocation(argsURL(ollamaChatArguments))
endfunction


# Conversation template on-click event handler
async function ollamaChatConversationOnTemplate(conversation):
    # Get the template prompts
    prompts = []
    for exchange in objectGet(conversation, 'exchanges'):
        arrayPush(prompts, objectGet(exchange, 'user'))
    endfor

    # Create a template from the conversation
    templateRequest = {'title': objectGet(conversation, 'title'), 'prompts': prompts}
    templateResponse = systemFetch({'url': 'createTemplate', 'body': jsonStringify(templateRequest)})
    templateResponse = if(templateResponse != null, jsonParse(templateResponse))
    templateID = if(templateResponse != null, objectGet(templateResponse, 'id'))

    # Navigate to the template editor
    if templateID != null:
        windowSetLocation(argsURL(ollamaChatArguments, {'id': templateID, 'view': 'template'}))
    endif
endfunction


# Prompt on-enter/on-click event handler
async function ollamaChatConversationOnPrompt(args, message):
    id = objectGet(args, 'id')

    # Get the prompt text
    prompt = if(message != null, message, stringTrim(documentInputValue(ollamaChatConversationPromptID)))
    if prompt == '':
        return
    endif

    # Starting a chat?
    if id == null:
        # Start the chat — include image if attached
        startBody = {'user': prompt}
        imgB64 = stringTrim(documentInputValue('oc-img-b64'))
        if imgB64 != '':
            objectSet(startBody, 'images', [imgB64])
        endif
        startRequest = jsonStringify(startBody)
        startResponse = systemFetch({'url': 'startConversation', 'body': startRequest})
        startResponse = if(startResponse != null, jsonParse(startResponse))
        if startResponse == null:
            return
        endif
        id = objectGet(startResponse, 'id')

        # Navigate to the conversation ID
        windowSetLocation(argsURL(ollamaChatArguments, {'id': id}, false, ollamaChatConversationBottomID))
        return
    endif

    # Check context usage — block if context is >= 90% full
    if conversation != null:
        exchanges = objectGet(conversation, 'exchanges')
        if arrayLength(exchanges):
            lastEx = arrayGet(exchanges, arrayLength(exchanges) - 1)
            pt = objectGet(lastEx, 'promptTokens')
            rt = objectGet(lastEx, 'responseTokens')
            cs = objectGet(lastEx, 'contextSize')
            if pt != null && cs != null && cs > 0:
                usedPct = mathFloor(100 * (pt + if(rt != null, rt, 0)) / cs)
                if usedPct >= 95:
                    ollamaChatConversationPage(args)
                    return
                endif
            endif
        endif
    endif

    # Reply to that chat — include image if attached
    replyBody = {'id': id, 'user': prompt}
    imgB64Reply = stringTrim(documentInputValue('oc-img-b64'))
    if imgB64Reply != '':
        objectSet(replyBody, 'images', [imgB64Reply])
    endif
    systemFetch({'url': 'replyConversation', 'body': jsonStringify(replyBody)})

    # Render the conversation page
    ollamaChatConversationPage(args)

    # Scroll to the bottom
    windowSetLocation(argsURL(ollamaChatArguments, null, false, ollamaChatConversationBottomID))
endfunction


# The bottom input bar element model (fixed position, ChatGPT style)
function ollamaChatConversationInputBarElements(args, conversation, generating):
    multiline = objectGet(args, 'multiline')
    action = objectGet(args, 'action')
    textView = objectGet(args, 'text')
    lang = objectGet(args, 'lang')

    # Compute URLs and callbacks
    multilineURL = argsURL(ollamaChatArguments, {'multiline': !multiline})
    markdownURL = argsURL(ollamaChatArguments, {'text': !textView})
    multilineFn = systemPartial(ollamaChatConversationOnClick, args, null, multilineURL)
    markdownClickFn = systemPartial(ollamaChatConversationOnClick, args, null, markdownURL)
    templateClickFn = systemPartial(ollamaChatConversationOnTemplate, conversation)

    # Get the saved session prompt, if any
    prompt = sessionStorageGet(ollamaChatConversationSessionKey)
    if prompt != null:
        sessionStorageRemove(ollamaChatConversationSessionKey)
    endif

    # Detect if model supports thinking (from last exchange)
    modelSupportsThinking = false
    if conversation != null:
        convExch = objectGet(conversation, 'exchanges')
        if arrayLength(convExch):
            lastExc = arrayGet(convExch, arrayLength(convExch) - 1)
            if objectHas(lastExc, 'modelSupportsThinking'):
                modelSupportsThinking = objectGet(lastExc, 'modelSupportsThinking')
            endif
        endif
    endif
    thinkingEnabled = if(conversation != null && objectHas(conversation, 'thinkingEnabled'), objectGet(conversation, 'thinkingEnabled'), null)

    # Build secondary controls (above input, only shown when conversation exists and not generating)
    secondaryControls = []
    if conversation != null && !generating:
        convId = objectGet(args, 'id')

        # Generate download URL
        markdownTitle = objectGet(conversation, 'title')
        markdownParts = ['# ' + markdownEscape(markdownTitle), '', '**Model:** ' + markdownEscape(objectGet(conversation, 'model'))]
        for exchange in objectGet(conversation, 'exchanges'):
            arrayPush(markdownParts, '', '## User:', '', objectGet(exchange, 'user'), '', '## Model:', '', objectGet(exchange, 'model'))
        endfor
        markdownText = arrayJoin(markdownParts, '\n')
        markdownDownloadURL = urlObjectCreate(markdownText, 'text/markdown')
        markdownFilename = regexReplace(regexNew('[\'"]'), stringLower(markdownTitle), '')
        markdownFilename = regexReplace(regexNew('[^a-z0-9]+'), markdownFilename, '-')
        markdownFilename = regexReplace(regexNew('^-'), markdownFilename, '')
        markdownFilename = regexReplace(regexNew('-$'), markdownFilename, '') + '.md'

        # Download link styled as text+icon button
        downloadAStyle = 'display: inline-flex; align-items: center; gap: 5px; padding: 5px 10px; border-radius: 8px; border: 1px solid var(--oc-border); background: transparent; color: var(--oc-text-2); font-size: 0.78rem; cursor: pointer; font-family: inherit; text-decoration: none; white-space: nowrap;'
        downloadHover = "this.style.borderColor='var(--oc-text-3)';this.style.color='var(--oc-text)';this.style.background='var(--oc-input-bar)';"
        downloadOut = "this.style.borderColor='var(--oc-border)';this.style.color='var(--oc-text-2)';this.style.background='transparent';"

        arrayPush(secondaryControls, { \
            'html': 'div', \
            'attr': {'class': 'oc-conv-toolbar', 'style': 'display: flex; gap: 0.35rem; margin-bottom: 0.5rem; justify-content: center; max-width: 760px; margin-left: auto; margin-right: auto; padding: 0 0.5rem; width: 100%; flex-wrap: wrap;'}, \
            'elem': [ \
                ollamaChatTextIconBtn(if(!textView, ollamaChatIconType, ollamaChatIconCode), if(!textView, tr(lang, 'plain_text'), tr(lang, 'markdown')), markdownClickFn), \
                { \
                    'html': 'a', \
                    'attr': { \
                        'href': markdownDownloadURL, \
                        'download': markdownFilename, \
                        'style': downloadAStyle, \
                        'onmouseover': downloadHover, \
                        'onmouseout': downloadOut \
                    }, \
                    'elem': [ollamaChatSVG(ollamaChatIconDownload, '13'), {'html': 'span', 'elem': {'text': tr(lang, 'download')}}] \
                }, \
                ollamaChatTextIconBtn(ollamaChatIconCode, tr(lang, 'save_template'), templateClickFn), \
                if(modelSupportsThinking, { \
                    'html': 'button', \
                    'attr': { \
                        'type': 'button', \
                        'style': 'display: inline-flex; align-items: center; gap: 5px; padding: 5px 10px; border-radius: 8px; border: 1px solid ' + if(thinkingEnabled == false, 'var(--oc-border)', 'var(--oc-accent)') + '; background: ' + if(thinkingEnabled == false, 'transparent', 'var(--oc-accent-bg)') + '; color: ' + if(thinkingEnabled == false, 'var(--oc-text-2)', 'var(--oc-accent)') + '; font-size: 0.78rem; cursor: pointer; font-family: inherit; white-space: nowrap;', \
                        'title': if(thinkingEnabled == false, 'Enable thinking mode', 'Disable thinking mode'), \
                        'onclick': "fetch('setConversationThinking',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({id:'" + convId + "',enabled:" + if(thinkingEnabled == false, 'true', 'false') + "})}).then(function(){location.reload();});" \
                    }, \
                    'elem': [ \
                        ollamaChatSVG(ollamaChatIconBrain, '13'), \
                        {'html': 'span', 'elem': {'text': if(thinkingEnabled == false, 'Thinking: off', 'Thinking: on')}} \
                    ] \
                }) \
            ] \
        })
    endif

    # Check if context is full (blocks sending new messages)
    contextFull = false
    if conversation != null:
        convExchanges = objectGet(conversation, 'exchanges')
        if arrayLength(convExchanges):
            lastExCheck = arrayGet(convExchanges, arrayLength(convExchanges) - 1)
            ptCheck = objectGet(lastExCheck, 'promptTokens')
            rtCheck = if(objectHas(lastExCheck, 'responseTokens'), objectGet(lastExCheck, 'responseTokens'), 0)
            csCheck = objectGet(lastExCheck, 'contextSize')
            if ptCheck != null && csCheck != null && csCheck > 0:
                contextFull = mathFloor(100 * (ptCheck + rtCheck) / csCheck) >= 95
            endif
        endif
    endif

    # The main input bar
    inputBar = { \
        'html': 'div', \
        'attr': { \
            'data-oc-input-bar': '1', \
            'style': 'display: flex; flex-direction: column; background: var(--oc-input-bar); border: 1px solid ' + if(contextFull, 'rgba(239,68,68,0.4)', 'var(--oc-border)') + '; border-radius: 16px; padding: 0.5rem 0.6rem 0.5rem 1rem; max-width: 760px; margin: 0 auto; width: 100%; opacity: ' + if(contextFull, '0.6', '1') + ';', \
            'ondragover': "event.preventDefault();this.style.outline='2px dashed #10a37f';this.style.outlineOffset='2px';", \
            'ondragleave': "this.style.outline='';this.style.outlineOffset='';", \
            'ondrop': "event.preventDefault();this.style.outline='';this.style.outlineOffset='';var f=event.dataTransfer.files[0];if(f)ocReadFile(f,'" + ollamaChatConversationPromptID + "');" \
        }, \
        'elem': [ \
            { \
                'html': 'div', 'attr': {'style': 'display: flex; align-items: ' + if(multiline, 'flex-end', 'center') + '; gap: 0.5rem;'}, \
                'elem': [ \
                ollamaChatIconBtn(ollamaChatIconMenu, if(multiline, tr(lang, 'multiline_off'), tr(lang, 'multiline_on')), multilineFn), \
            { \
                'html': if(multiline, 'textarea', 'input'), \
                'attr': { \
                    'autocomplete': 'off', \
                    'id': ollamaChatConversationPromptID, \
                    'placeholder': if(contextFull, 'Context window full — start a new chat', tr(lang, 'message_placeholder') + '  (type @ to attach files, images or URLs)'), \
                    'rows': if(multiline, 8), \
                    'disabled': if(contextFull, 'disabled'), \
                    'style': 'background: transparent; border: none; flex: 1; font-size: 0.9375rem; font-family: inherit; color: var(--oc-text); outline: none; padding: 0.3rem 0.25rem; min-width: 0; resize: none; line-height: 1.5;', \
                    'type': if(!multiline, 'text'), \
                    'value': if(!multiline, prompt), \
                    'oninput': if(multiline, "this.style.height='auto';this.style.height=Math.min(this.scrollHeight,300)+'px';ocCheckAtMention(this);", "ocCheckAtMention(this);") \
                }, \
                'elem': if(multiline && prompt != null, {'text': prompt}), \
                'callback': if(!multiline && !generating && !contextFull, \
                    {'keyup': systemPartial(formsTextOnKeyup, systemPartial(ollamaChatConversationOnPrompt, args))} \
                ) \
            }, \
            if(!generating && !contextFull, { \
                'html': 'button', 'attr': { \
                    'type': 'button', 'title': 'Send message', \
                    'style': 'display: inline-flex; align-items: center; justify-content: center; width: 34px; height: 34px; border-radius: 50%; border: none; cursor: pointer; background: var(--oc-text); color: var(--oc-bg); flex-shrink: 0; padding: 0;', \
                    'onmouseover': "this.style.opacity='0.85';", \
                    'onmouseout': "this.style.opacity='1';", \
                    'onclick': "ocInjectFile('" + ollamaChatConversationPromptID + "');" \
                }, \
                'callback': {'click': systemPartial(ollamaChatConversationOnPrompt, args)}, \
                'elem': {'svg': 'svg', 'attr': {'width': '16', 'height': '16', 'viewBox': '0 0 24 24', 'fill': 'none', 'stroke': 'currentColor', 'stroke-width': '2.5', 'stroke-linecap': 'round', 'stroke-linejoin': 'round'}, 'elem': ollamaChatIconArrowUp} \
            }), \
            if(generating, ollamaChatStopBtn(systemPartial(ollamaChatConversationOnClick, args, 'stopConversation'))) \
        ] \
        } \
    ] \
    }

    # Token progress bar — built from last exchange data
    tokenBar = null
    if conversation != null:
        exchanges = objectGet(conversation, 'exchanges')
        if arrayLength(exchanges):
            lastEx = arrayGet(exchanges, arrayLength(exchanges) - 1)
            pt = objectGet(lastEx, 'promptTokens')
            if pt != null:
                rt = if(objectHas(lastEx, 'responseTokens'), objectGet(lastEx, 'responseTokens'), 0)
                cs = objectGet(lastEx, 'contextSize')
                total = pt + rt
                pct = if(cs != null && cs > 0, mathFloor(1000 * total / cs) / 10, null)
                barPct = if(pct != null, if(pct > 100, 100, pct), 0)
                barColor = if(pct == null, '#10a37f', \
                    if(pct > 90, '#ef4444', \
                    if(pct > 75, '#f97316', \
                    if(pct > 50, '#eab308', '#10a37f'))))
                usedLabel = numberToFixed(pt, 0) + ' prompt + ' + numberToFixed(rt, 0) + ' response = ' + numberToFixed(total, 0)
                ctxLabel = if(cs != null, ' / ' + numberToFixed(cs, 0), '')
                pctLabel = if(pct != null, ' (' + numberToFixed(pct, 1) + '%)', '')
                contextFull = pct != null && pct >= 95

                # Warning row — shown when context is nearly full
                warningRow = if(contextFull, { \
                    'html': 'div', \
                    'attr': {'style': 'max-width: 760px; margin: 0 auto 0.4rem; padding: 0.4rem 0.75rem; width: 100%; background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.3); border-radius: 8px; display: flex; align-items: center; gap: 0.5rem; box-sizing: border-box;'}, \
                    'elem': [ \
                        ollamaChatSVG([{'svg': 'path', 'attr': {'d': 'M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z'}}, {'svg': 'line', 'attr': {'x1': '12', 'y1': '9', 'x2': '12', 'y2': '13'}}, {'svg': 'line', 'attr': {'x1': '12', 'y1': '17', 'x2': '12.01', 'y2': '17'}}], '14'), \
                        {'html': 'span', 'attr': {'style': 'font-size: 0.78rem; color: #ef4444; flex: 1;'}, 'elem': {'text': 'Context window full. Start a new chat to continue.'}}, \
                        { \
                            'html': 'a', \
                            'attr': {'href': argsURL(ollamaChatArguments, {'view': null, 'id': null, 'action': null}, true), \
                                'style': 'font-size: 0.78rem; color: #ef4444; font-weight: 600; white-space: nowrap;', \
                                'onmouseover': "this.style.opacity='0.8';", \
                                'onmouseout': "this.style.opacity='1';"}, \
                            'elem': {'text': 'New Chat →'} \
                        } \
                    ] \
                })

                tokenBar = { \
                    'html': 'div', \
                    'attr': {'style': 'max-width: 760px; margin: 0 auto 0.6rem; padding: 0 0.5rem; width: 100%;'}, \
                    'elem': [ \
                        warningRow, \
                        { \
                            'html': 'div', \
                            'attr': {'style': 'display: flex; justify-content: space-between; align-items: baseline; font-size: 0.72rem; color: var(--oc-text-3); margin-bottom: 0.3rem;'}, \
                            'elem': [ \
                                {'html': 'span', 'elem': {'text': usedLabel}}, \
                                {'html': 'span', 'attr': {'style': 'color: ' + barColor + '; font-weight: 500;'}, 'elem': {'text': numberToFixed(total, 0) + ctxLabel + ' tokens' + pctLabel}} \
                            ] \
                        }, \
                        { \
                            'html': 'div', \
                            'attr': {'style': 'height: 5px; background: var(--oc-border); border-radius: 3px; overflow: hidden;'}, \
                            'elem': { \
                                'html': 'div', \
                                'attr': {'style': 'height: 100%; width: ' + numberToFixed(barPct, 1) + '%; background: ' + barColor + '; border-radius: 3px;'} \
                            } \
                        } \
                    ] \
                }
            endif
        endif
    endif

    return { \
        'html': 'div', \
        'attr': { \
            'class': 'oc-input-bar-wrap', \
            'style': 'position: fixed; left: 260px; right: 0; bottom: 0; padding: 0.5rem 2rem 1.25rem; background: linear-gradient(transparent, var(--oc-bg) 25%);' \
        }, \
        'elem': [ \
            secondaryControls, \
            tokenBar, \
            inputBar \
        ] \
    }
endfunction


# Create an SVG button element model
function ollamaChatConversationSVGButton(width, height, viewSize, symbolPath, symbolFill, backgroundColor, callback):
    return { \
        'html': 'button', \
        'attr': { \
            'type': 'button', \
            'style': arrayJoin([ \
                'background: transparent', \
                'border: none', \
                'padding: 0', \
                'cursor: pointer', \
                'flex-shrink: 0' \
            ], '; '), \
            'onmouseover': "this.children[0].style.opacity='" + if(backgroundColor != 'none', '0.8', '0.6') + "';", \
            'onmouseout': "this.children[0].style.opacity='1';" \
        }, \
        'elem': { \
            'svg': 'svg', \
            'attr': { \
                'width': numberToFixed(width, ollamaChatConversationSVGPrecision), \
                'height': numberToFixed(height, ollamaChatConversationSVGPrecision), \
                'viewBox': '0 0 ' + viewSize + ' ' + viewSize, \
                'fill': 'none', \
                'style': 'vertical-align: middle', \
                'preserveAspectRatio': 'none' \
            }, \
            'elem': [ \
                if(backgroundColor != 'none', { \
                    'svg': 'circle', \
                    'attr': { \
                        'cx': numberToFixed(0.5 * viewSize, ollamaChatConversationSVGPrecision), \
                        'cy': numberToFixed(0.5 * viewSize, ollamaChatConversationSVGPrecision), \
                        'r': numberToFixed(0.5 * viewSize, ollamaChatConversationSVGPrecision), \
                        'stroke': 'none', \
                        'fill': backgroundColor \
                    } \
                }), \
                { \
                    'svg': 'path', \
                    'attr': { \
                        'd': symbolPath, \
                        'stroke': if(symbolFill == 'none', 'var(--oc-text)', 'none'), \
                        'fill': symbolFill, \
                        'stroke-width': numberToFixed(0.1 * viewSize) \
                    } \
                } \
            ] \
        }, \
        'callback': {'click': callback} \
    }
endfunction


# New chat welcome area — clean, centered, no templates (go to Templates section for those)
function ollamaChatConversationNewChatArea(args, lang):
    elementModelRender({ \
        'html': 'div', \
        'attr': {'class': 'oc-new-chat-welcome', 'style': 'display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 2rem 1.5rem 1rem; min-height: 40vh; gap: 0.75rem;'}, \
        'elem': [ \
            {'html': 'div', 'attr': {'style': 'font-size: 2.5rem; line-height: 1;'}, 'elem': {'text': '🦙'}}, \
            {'html': 'h2', 'attr': {'style': 'font-size: 1.2rem; font-weight: 600; color: var(--oc-text); margin: 0;'}, 'elem': {'text': 'What can I help you with?'}}, \
            {'html': 'p', 'attr': {'style': 'font-size: 0.875rem; color: var(--oc-text-3); margin: 0; max-width: 340px; line-height: 1.5;'}, 'elem': {'text': 'Type your message below to start a conversation.'}} \
        ] \
    })
endfunction


# Build template tile buttons for new chat area
function ollamaChatConversationTemplateTiles(templates):
    tiles = []
    for template in templates:
        templateID = objectGet(template, 'id')
        templateTitle = objectGet(template, 'title')
        arrayPush(tiles, { \
            'html': 'button', \
            'attr': { \
                'type': 'button', \
                'class': 'oc-template-tile', \
                'style': 'display: inline-flex; align-items: center; gap: 6px; padding: 8px 14px; border-radius: 20px; border: 1px solid var(--oc-border); background: var(--oc-bg-2); color: var(--oc-text-2); font-size: 0.85rem; cursor: pointer; font-family: inherit; white-space: nowrap;', \
                'onmouseover': ollamaChatHoverBorderOn, \
                'onmouseout': ollamaChatHoverBorderOut \
            }, \
            'callback': {'click': systemPartial(ollamaChatConversationOnRunTemplate, templateID)}, \
            'elem': [ollamaChatSVG(ollamaChatIconTemplate, '13'), {'html': 'span', 'elem': {'text': templateTitle}}] \
        })
    endfor
    return tiles
endfunction


# Run a template from new chat area
async function ollamaChatConversationOnRunTemplate(templateID):
    templateResponse = systemFetch('getTemplate?id=' + templateID)
    templateResponse = if(templateResponse != null, jsonParse(templateResponse))
    if templateResponse == null:
        return
    endif
    if objectGet(templateResponse, 'variables'):
        windowSetLocation(argsURL(ollamaChatArguments, {'view': 'variables', 'id': templateID}))
        return
    endif
    startResponse = systemFetch({'url': 'startTemplate', 'body': jsonStringify({'id': templateID})})
    startResponse = if(startResponse != null, jsonParse(startResponse))
    if startResponse != null:
        windowSetLocation(argsURL(ollamaChatArguments, {'id': objectGet(startResponse, 'id')}, false, ollamaChatConversationBottomID))
    endif
endfunction
